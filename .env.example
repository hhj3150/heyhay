# HEY HAY MILK ERP 환경변수 템플릿
# 복사 후 .env 로 저장: cp .env.example .env

# --- 데이터베이스 ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=heyhay_erp
DB_USER=postgres
DB_PASSWORD=heyhay2025!

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT (반드시 변경!) ---
JWT_SECRET=your-jwt-secret-change-me-32chars-min
JWT_REFRESH_SECRET=your-refresh-secret-change-me-32chars

# --- 서버 ---
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# --- 네이버 커머스 API ---
# 네이버 커머스 센터 > 애플리케이션 관리에서 발급
NAVER_COMMERCE_CLIENT_ID=your-app-id
NAVER_COMMERCE_CLIENT_SECRET=your-app-secret

# --- 기타 외부 API ---
# SMAXTEC_API_KEY=
# ANTHROPIC_API_KEY=
